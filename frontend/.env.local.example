# ── Sentirion Frontend — Environment Variables ────────────────────────────────
# Copy this file to .env.local and fill in real values before running.
# Never commit .env.local to version control.

# URL of the Python backend — used by Next.js API routes (server-side only)
# Development default: http://127.0.0.1:3001
# Docker / production: http://backend:3001  (or your actual backend URL)
SENTIRION_BACKEND_URL=http://127.0.0.1:3001
