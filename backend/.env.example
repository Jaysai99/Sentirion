# ── Sentirion Backend — Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in real values before running.
# Never commit .env to version control.

# Server
HOST=127.0.0.1          # Use 0.0.0.0 to accept external connections (e.g. in Docker)
PORT=3001

# CORS — comma-separated list of allowed frontend origins
# In production set this to your actual frontend domain(s), e.g.:
#   ALLOWED_ORIGINS=https://sentirion.yourcompany.com
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# SEC Edgar (required for SEC filing downloads)
# Register at https://efts.sec.gov/LATEST/search-index/company-search
SEC_COMPANY_NAME=YourCompanyName
SEC_CONTACT_EMAIL=your@email.com

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
