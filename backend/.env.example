# ── Sentirion Backend — Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in real values before running.
# Never commit .env to version control.

# ── Server ────────────────────────────────────────────────────────────────────
HOST=127.0.0.1          # Use 0.0.0.0 for Docker / external access
PORT=3001

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── SEC Edgar ─────────────────────────────────────────────────────────────────
# Required for SEC filing downloads (EDGAR fair-use policy)
SEC_COMPANY_NAME=YourCompanyName
SEC_CONTACT_EMAIL=your@email.com

# ── Twitter / X ───────────────────────────────────────────────────────────────
# Optional. Without this, twitter_ingestion falls back to ntscraper (Nitter).
# Get a Bearer Token at https://developer.twitter.com/en/portal/dashboard
# Free tier: ~500k tweet reads/month, 7-day search window.
TWITTER_BEARER_TOKEN=

# ── NewsAPI ───────────────────────────────────────────────────────────────────
# Optional. Without this, news comes from free RSS feeds only.
# Adds WSJ, FT, Bloomberg, Business Insider coverage.
# Get a free key (100 req/day) at https://newsapi.org/register
NEWSAPI_KEY=

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
